<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Workers - KOVA Sales</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="navbar-brand">KO<span>VA</span> Sales</div>
    <ul class="navbar-nav">
      <li><a href="/dashboard">Dashboard</a></li>
      <li><a href="/sales">Sales</a></li>
      <li><a href="/reports">Reports</a></li>
      <% if (user.role === 'admin') { %>
        <li><a href="/workers" class="active">Workers</a></li>
      <% } %>
      <li><a href="/profile">Profile</a></li>
      <li class="user-info">Hello, <strong><%= user.fullName %></strong></li>
      <li><a href="/auth/logout">Logout</a></li>
    </ul>
  </nav>

  <div class="container">
    <h1 class="page-title">Manage Workers</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="card">
      <div class="card-header">Add New Worker</div>
      <form method="POST" action="/workers/add">
        <div class="form-grid">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="full_name" placeholder="e.g. John Deng" required>
          </div>
          <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" placeholder="Choose username" required>
          </div>
          <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="Min 6 characters" required minlength="6">
          </div>
          <div class="form-group">
            <button type="submit" class="btn btn-success" style="height:42px;margin-top:auto;">Add Worker</button>
          </div>
        </div>
      </form>
    </div>

    <div class="card">
      <div class="card-header">All Workers (<%= workers.length %>)</div>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Username</th>
              <th>Role</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% workers.forEach(w => { %>
              <tr>
                <td><strong><%= w.full_name %></strong></td>
                <td><%= w.username %></td>
                <td><span class="badge <%= w.role === 'admin' ? 'badge-yogurt' : '' %>"><%= w.role %></span></td>
                <td><%= new Date(w.created_at).toLocaleDateString('en-GB') %></td>
                <td>
                  <% if (w.role !== 'admin') { %>
                    <form method="POST" action="/workers/reset-password/<%= w.id %>" style="display:inline;">
                      <input type="password" name="new_password" placeholder="New password" style="padding:4px 8px;font-size:12px;border:1px solid var(--border);border-radius:4px;width:120px;" required minlength="6">
                      <button type="submit" class="btn btn-outline btn-sm" onclick="return confirm('Reset password for <%= w.username %>?')">Reset PW</button>
                    </form>
                    <form method="POST" action="/workers/delete/<%= w.id %>" style="display:inline;" onsubmit="return confirm('Delete worker <%= w.username %>? This cannot be undone.')">
                      <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  <% } else { %>
                    <span style="color:var(--text-secondary);font-size:13px;">Admin</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>
