<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile - KOVA Sales</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="navbar-brand">KO<span>VA</span> Sales</div>
    <ul class="navbar-nav">
      <li><a href="/dashboard">Dashboard</a></li>
      <li><a href="/sales">Sales</a></li>
      <li><a href="/reports">Reports</a></li>
      <% if (user.role === 'admin') { %>
        <li><a href="/workers">Workers</a></li>
      <% } %>
      <li><a href="/profile" class="active">Profile</a></li>
      <li class="user-info">Hello, <strong><%= user.fullName %></strong></li>
      <li><a href="/auth/logout">Logout</a></li>
    </ul>
  </nav>

  <div class="container">
    <h1 class="page-title">My Profile</h1>

    <div class="grid-2">
      <div class="card">
        <div class="card-header">Account Info</div>
        <p><strong>Name:</strong> <%= user.fullName %></p>
        <p><strong>Username:</strong> <%= user.username %></p>
        <p><strong>Role:</strong> <span class="badge <%= user.role === 'admin' ? 'badge-yogurt' : '' %>"><%= user.role %></span></p>
      </div>

      <div class="card">
        <div class="card-header">Change Password</div>

        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form method="POST" action="/profile/change-password">
          <div class="form-group" style="margin-bottom:12px;">
            <label>Current Password</label>
            <input type="password" name="current_password" required>
          </div>
          <div class="form-group" style="margin-bottom:12px;">
            <label>New Password</label>
            <input type="password" name="new_password" required minlength="6">
          </div>
          <div class="form-group" style="margin-bottom:12px;">
            <label>Confirm New Password</label>
            <input type="password" name="confirm_password" required minlength="6">
          </div>
          <button type="submit" class="btn btn-primary">Update Password</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
