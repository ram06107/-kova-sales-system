<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - KOVA Sales</title>
  <link rel="stylesheet" href="/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
  <nav class="navbar">
    <div class="navbar-brand">KO<span>VA</span> SALES</div>
    <ul class="navbar-nav">
      <li><a href="/dashboard" class="active">Dashboard</a></li>
      <li><a href="/sales">Sales</a></li>
      <li><a href="/stock">Stock</a></li>
      <li><a href="/notes">Notes</a></li>
      <li><a href="/reports">Reports</a></li>
      <% if (user.role === 'admin') { %>
        <li><a href="/workers">Workers</a></li>
      <% } %>
      <li><a href="/profile">Profile</a></li>
      <li class="user-info">Hello, <strong><%= user.fullName %></strong></li>
      <li><a href="/auth/logout">Logout</a></li>
    </ul>
  </nav>

  <div class="container">
    <h1 class="page-title">Sales Dashboard</h1>

    <h3 style="font-size:14px;color:var(--ink-faint);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.5px;">Today's Performance</h3>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="label">Total Revenue Today</div>
        <div class="value"><%= daily.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="growth <%= parseFloat(daily.growth) >= 0 ? 'up' : 'down' %>">
          <%= parseFloat(daily.growth) >= 0 ? '&#9650;' : '&#9660;' %> <%= Math.abs(daily.growth) %>% vs yesterday
        </div>
      </div>
      <div class="stat-card yogurt">
        <div class="label">Yogurt Sales</div>
        <div class="value"><%= daily.yogurt.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="sub"><%= daily.yogurt.qty %> units sold</div>
      </div>
      <div class="stat-card tea">
        <div class="label">Tea Sales</div>
        <div class="value"><%= daily.tea.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="sub"><%= daily.tea.qty %> units sold</div>
      </div>
    </div>

    <h3 style="font-size:14px;color:var(--ink-faint);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.5px;">This Week (Last 7 Days)</h3>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="label">Weekly Revenue</div>
        <div class="value"><%= weekly.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="growth <%= parseFloat(weekly.growth) >= 0 ? 'up' : 'down' %>">
          <%= parseFloat(weekly.growth) >= 0 ? '&#9650;' : '&#9660;' %> <%= Math.abs(weekly.growth) %>% vs last week
        </div>
      </div>
      <div class="stat-card yogurt">
        <div class="label">Weekly Yogurt</div>
        <div class="value"><%= weekly.yogurt.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="sub"><%= weekly.yogurt.qty %> units total</div>
      </div>
      <div class="stat-card tea">
        <div class="label">Weekly Tea</div>
        <div class="value"><%= weekly.tea.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="sub"><%= weekly.tea.qty %> units total</div>
      </div>
    </div>

    <h3 style="font-size:14px;color:var(--ink-faint);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.5px;">This Month</h3>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="label">Monthly Revenue</div>
        <div class="value"><%= monthly.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="growth <%= parseFloat(monthly.growth) >= 0 ? 'up' : 'down' %>">
          <%= parseFloat(monthly.growth) >= 0 ? '&#9650;' : '&#9660;' %> <%= Math.abs(monthly.growth) %>% vs last month
        </div>
      </div>
      <div class="stat-card yogurt">
        <div class="label">Monthly Yogurt</div>
        <div class="value"><%= monthly.yogurt.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="sub"><%= monthly.yogurt.qty %> units total</div>
      </div>
      <div class="stat-card tea">
        <div class="label">Monthly Tea</div>
        <div class="value"><%= monthly.tea.total.toLocaleString() %> <span class="currency">SSP</span></div>
        <div class="sub"><%= monthly.tea.qty %> units total</div>
      </div>
    </div>

    <% if (stock.total > 0) { %>
    <h3 style="font-size:14px;color:var(--ink-faint);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.5px;">Yogurt Stock</h3>
    <div class="stats-grid" style="grid-template-columns: 1fr 2fr;">
      <div class="stat-card" style="border-left:3px solid <%= stock.remaining > stock.total * 0.3 ? 'var(--yogurt)' : 'var(--danger)' %>;">
        <div class="label">Remaining Cups</div>
        <div class="value"><%= stock.remaining %> <span class="currency">/ <%= stock.total %></span></div>
        <div class="sub">= <%= (stock.remaining * 400 / 1000).toFixed(1) %>L of <%= (stock.total * 400 / 1000).toFixed(0) %>L</div>
      </div>
      <div class="stat-card">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-family:'Inter',sans-serif;font-size:11px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:1px;">
          <span>Consumption</span>
          <span><%= stock.total > 0 ? Math.round((stock.total - stock.remaining) / stock.total * 100) : 0 %>% used</span>
        </div>
        <div style="height:8px;background:var(--rule-light);width:100%;">
          <div style="height:100%;background:<%= stock.remaining > stock.total * 0.3 ? 'var(--yogurt)' : 'var(--danger)' %>;width:<%= stock.total > 0 ? Math.round(stock.remaining / stock.total * 100) : 0 %>%;transition:width 0.3s;"></div>
        </div>
        <div style="text-align:center;margin-top:12px;">
          <a href="/stock" class="btn btn-outline btn-sm">Manage Stock</a>
        </div>
      </div>
    </div>
    <% } %>

    <div class="grid-2">
      <div class="card">
        <div class="card-header">Daily Revenue (Last 7 Days)</div>
        <div class="chart-container">
          <canvas id="revenueChart"></canvas>
        </div>
      </div>
      <div class="card">
        <div class="card-header">Recent Transactions</div>
        <% if (recentSales.length === 0) { %>
          <p style="color:var(--ink-faint);text-align:center;padding:40px 0;">No sales recorded yet. <a href="/sales">Add your first sale</a></p>
        <% } else { %>
          <table>
            <thead>
              <tr><th>Date</th><th>Product</th><th>Qty</th><th>Total</th></tr>
            </thead>
            <tbody>
              <% recentSales.forEach(s => { %>
                <tr>
                  <td><%= s.sale_date %></td>
                  <td><span class="badge badge-<%= s.product %>"><%= s.product %></span></td>
                  <td><%= s.quantity %></td>
                  <td><strong><%= s.total_amount.toLocaleString() %> SSP</strong></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div style="text-align:center;margin-top:12px;">
            <a href="/sales" class="btn btn-outline btn-sm">View All Sales</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    const ctx = document.getElementById('revenueChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: <%- JSON.stringify(chart.labels) %>,
        datasets: [
          {
            label: 'Yogurt (SSP)',
            data: <%- JSON.stringify(chart.yogurt) %>,
            backgroundColor: 'rgba(52, 168, 83, 0.7)',
            borderColor: '#34a853',
            borderWidth: 1,
            borderRadius: 4
          },
          {
            label: 'Tea (SSP)',
            data: <%- JSON.stringify(chart.tea) %>,
            backgroundColor: 'rgba(251, 188, 4, 0.7)',
            borderColor: '#fbbc04',
            borderWidth: 1,
            borderRadius: 4
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'top' } },
        scales: {
          x: { stacked: true, grid: { display: false } },
          y: { stacked: true, beginAtZero: true, ticks: { callback: v => v.toLocaleString() + ' SSP' } }
        }
      }
    });
  </script>
</body>
</html>
