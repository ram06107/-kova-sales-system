<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reports - KOVA Sales</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="navbar-brand">KO<span>VA</span> SALES</div>
    <ul class="navbar-nav">
      <li><a href="/dashboard">Dashboard</a></li>
      <li><a href="/sales">Sales</a></li>
      <li><a href="/stock">Stock</a></li>
      <li><a href="/notes">Notes</a></li>
      <li><a href="/reports" class="active">Reports</a></li>
      <% if (user.role === 'admin') { %>
        <li><a href="/workers">Workers</a></li>
      <% } %>
      <li><a href="/profile">Profile</a></li>
      <li class="user-info">Hello, <strong><%= user.fullName %></strong></li>
      <li><a href="/auth/logout">Logout</a></li>
    </ul>
  </nav>

  <div class="container">
    <h1 class="page-title">Weekly Reports</h1>
    <p style="color:var(--text-secondary);margin-bottom:24px;">Download detailed weekly PDF reports for yogurt and tea sales in South Sudanese Pounds (SSP).</p>

    <% weeks.forEach((week, idx) => { %>
      <div class="report-card">
        <div class="week-info">
          <h3>Week: <%= week.label %></h3>
          <p>
            <span style="color:var(--accent);">Yogurt: <%= week.yogurt.total.toLocaleString() %> SSP</span> &nbsp;|&nbsp;
            <span style="color:#b05a00;">Tea: <%= week.tea.total.toLocaleString() %> SSP</span>
          </p>
        </div>
        <div class="week-amounts">
          <span class="grand-total"><%= week.grandTotal.toLocaleString() %> SSP</span>
          <a href="/reports/pdf/<%= idx %>" class="btn btn-primary btn-sm" target="_blank">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
              <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
            </svg>
            Download PDF
          </a>
        </div>
      </div>
    <% }) %>
  </div>
</body>
</html>
